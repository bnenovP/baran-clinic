pipeline {
    agent any

    tools {
        gradle 'gradle-baran-clinic'
    }

    stages {
        stage('Unit Tests - Backend') {
            steps {
                withGradle() {
                    sh './gradlew clean test --tests "com.example.baranclinic.clinical.domain.repository.*" --tests "com.example.baranclinic.crm.domain.repository.*"'
                }
            }
        }
    }
}
