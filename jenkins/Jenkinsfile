pipeline {
    agent any

    tools {
        gradle 'gradle-baran-clinic'
    }

    environment {
          REPORT_PATH='build/test-results/test/*.xml'
      }

    stages {
        stage('Unit Tests - Backend') {
            steps {
                withGradle() {
                    sh '''
                    ./gradlew clean test --tests "com.example.baranclinic.clinical.domain.common.*" \
                    --tests "com.example.baranclinic.clinical.domain.service.*" \
                    --tests "com.example.baranclinic.crm.domain.common.*" \
                    --tests "com.example.baranclinic.crm.domain.service.*" \
                    '''
                }
            }
        }
        stage('Rest Tests - Backend') {
            steps {
                wihGradle() {
                    sh './gradlew clean test --tests "com.example.baranclinic.crm.domain.rest.*"'
                }
            }
        }
    }
}
