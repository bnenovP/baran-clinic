pipeline {
    agent any

    stages {

    stage('Build') {
        steps {
            echo 'Building the project with Gradle...'
            sh './gradlew clean build -x test'
        }
    }

        stage('Unit Tests - Backend') {
            steps {
                sh '''
                ./gradlew test --tests "com.example.baranclinic.clinical.domain.common.*" \
                --tests "com.example.baranclinic.clinical.domain.service.*" \
                --tests "com.example.baranclinic.crm.domain.common.*" \
                --tests "com.example.baranclinic.crm.domain.service.*" \
                '''
            }
        }

        stage('Repository Tests - Backend') {
            steps {
               sh '''
               ./gradlew test --tests "com.example.baranclinic.crm.domain.repository.*" \
               --tests "com.example.baranclinic.clinic.domain.repository.*"
               '''
            }
        }

        stage('Rest Tests - Backend') {
            steps {
               sh './gradlew test --tests "com.example.baranclinic.crm.domain.rest.*"'
            }
        }

        stage('Launch Application') {
            agent {
                docker {
                    image 'docker:27.5.1'
                    reuseNode true
                    args '-v /var/run/docker.sock:/var/run/docker.sock -u 0'
                }
            }
            steps {
                sh 'docker-compose up --build -d'
            }
        }
    }
}
